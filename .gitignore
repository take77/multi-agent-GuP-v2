# ══════════════════════════════════════════════════
# Whitelist-based .gitignore
# デフォルト全除外 → OSS公開対象のみ許可
# ══════════════════════════════════════════════════

# Step 1: 全て除外
*

# Step 2: ディレクトリの探索を許可（中身は個別に許可）
!*/

# Node.js dependencies (must be AFTER !*/ to take effect in whitelist mode)
node_modules/
scripts/monitor/node_modules/

# Step 3: OSS公開対象ファイルを許可
!.gitignore
!.gitattributes
!.gitleaks.toml
!CLAUDE.md
!LICENSE
!README.md
!README_ja.md
!CONTRIBUTING.md
!SECURITY.md

# Claude Code settings (spinner verbs only, no secrets)
!.claude/
!.claude/settings.json
!.claude/hooks/
!.claude/hooks/session_start.sh
!.claude/agents/
!.claude/agents/*.md

# Persona files (character definitions — safe for OSS)
!persona/
!persona/*.md

# Instructions (core OSS)
!instructions/
!instructions/shogun.md
!instructions/karo.md
!instructions/ashigaru.md
!instructions/battalion_commander.md
!instructions/chief_of_staff.md
